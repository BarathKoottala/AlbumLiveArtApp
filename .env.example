# Copy to .env and fill in your Spotify app credentials (the app loads .env on
# startup). Create an app at https://developer.spotify.com/dashboard and add the
# redirect URI there too.
SPOTIFY_CLI_CLIENT_ID=your_client_id
SPOTIFY_CLI_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback/

# Tempo (BPM) for the vinyl spin speed. Free key: https://getsongbpm.com/api
# (their TOS requires the "BPM data by GetSongBPM" backlink, which the page shows)
GETSONGBPM_API_KEY=your_getsongbpm_key
